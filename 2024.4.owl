    <DataPropertyAssertion>
        <DataProperty abbreviatedIRI="sdo:name"/>
        <NamedIndividual IRI="Cepea"/>
        <Literal xml:lang="en">CEPEA - Center for Advanced Studies on Applied Economics</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty abbreviatedIRI="sdo:name"/>
        <NamedIndividual IRI="Cepea"/>
        <Literal xml:lang="pt-br">CEPEA - Centro de Estudos Avançados em Economia Aplicada</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty abbreviatedIRI="sdo:url"/>
        <NamedIndividual IRI="Cepea"/>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#anyURI">https://www.cepea.esalq.usp.br/</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="http://purl.org/alm/meta/statisticalMethod"/>
        <NamedIndividual IRI="boiGordoCepeaB3"/>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#anyURI">https://www.cepea.esalq.usp.br/br/metodologia/metodologia-boi-gordo.aspx</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="http://purl.org/dc/terms/description"/>
        <NamedIndividual IRI="boiGordoCepeaB3"/>
        <Literal datatypeIRI="http://www.w3.org/2000/01/rdf-schema#Literal">Bovinos machos, com 16 (dezesseis) arrobas líquidas ou mais de carcaça e idade máxima de 42 (quarenta e dois) meses, advindos do Estado de São Paulo, de acordo com as especificações do contrato futuro de boi gordo da B3. O Indicador considera animais cuja carne pode ter  como destinos os mercados interno e externo, inclusive: a) Europa; b) os que se enquadram nos critérios de cota Hilton; c) China; etc.. Nesse sentido, preços referentes a essas condições podem fazer parte da amostra para cálculo do Indicador, desde que atendam aos critérios estatísticos estabelecidos em metodologia.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="http://purl.org/dc/terms/hasVersion"/>
        <NamedIndividual IRI="boiGordoCepeaB3"/>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#float">1.0</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="http://purl.org/dc/terms/language"/>
        <NamedIndividual IRI="boiGordoCepeaB3"/>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#language">pt-br</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="http://purl.org/dc/terms/license"/>
        <NamedIndividual IRI="boiGordoCepeaB3"/>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#anyURI">https://creativecommons.org/licenses/by-nc/4.0/</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="http://purl.org/dc/terms/modified"/>
        <NamedIndividual IRI="boiGordoCepeaB3"/>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#date">2024-05-19</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="http://purl.org/dc/terms/title"/>
        <NamedIndividual IRI="boiGordoCepeaB3"/>
        <Literal xml:lang="pt-br">INDICADOR DO BOI GORDO CEPEA/B3</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty abbreviatedIRI="sdo:location"/>
        <NamedIndividual IRI="boiGordoCepeaB3"/>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#anyURI">https://www.geonames.org/3448433/sao-paulo.html</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
