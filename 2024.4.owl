    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>boiGordo</IRI>
        <Literal xml:lang="pt-br">Boi gordo</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:relatedMatch"/>
        <IRI>boiGordo</IRI>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#anyURI">http://dbpedia.org/resource/Fed_cattle</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://purl.org/dc/elements/1.1/description"/>
        <IRI>boiGordoCepeaB3</IRI>
        <Literal xml:lang="pt-br">O Indicador do boi gordo CEPEA/B3 é uma média diária ponderada de preços por arroba à vista de boi gordo no estado de São Paulo, elaborado pelo Cepea (Centro de Estudos Avançados em Economia Aplicada), da Esalq/USP, em parceria com a B3. O Indicador é divulgado em todos os dias úteis, de forma ininterrupta, desde março de 1994. A média dos Indicadores dos últimos cinco dias úteis de um determinado mês é utilizada pela B3 para liquidar os contratos futuros de boi gordo lá negociados. A metodologia completa do Indicador está disponível nos sites do Cepea e da B3. Dada a ampla divulgação que o Cepea dá aos seus resultados, o Indicador CEPEA/B3 tem sido usado espontaneamente pelos agentes do mercado físico para negócios a termo. O Cepea não tem, evidentemente, qualquer influência sobre os níveis de preços negociados entre as partes no mercado. Procura, sim, coletar esses preços para compor o Indicador.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>boiGordoCepeaB3</IRI>
        <Literal xml:lang="en">CEPEA/B3 Fed Cattle Price Iindex São Paulo State</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>boiGordoCepeaB3</IRI>
        <Literal xml:lang="pt-br">Indicador do Boi Gordo Cepea/B3</Literal>
    </AnnotationAssertion>
